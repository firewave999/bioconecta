NODE_ENV=development

# App URLs
APP_WEB_URL=http://localhost:3000
APP_API_URL=http://localhost:4000
APP_API_PORT=4000

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bioconecta
POSTGRES_USER=bioconecta
POSTGRES_PASSWORD=bioconecta_dev_password
DATABASE_URL=postgresql://bioconecta:bioconecta_dev_password@localhost:5432/bioconecta

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Auth secrets for development only. Replace in staging/production.
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TOKEN_TTL_SECONDS=900
JWT_REFRESH_TOKEN_TTL_DAYS=30
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Mail / Brevo
BREVO_API_KEY=
MAIL_FROM_EMAIL=contato@seudominio.com
MAIL_FROM_NAME=BioConecta

# Uploads
UPLOAD_STORAGE_PATH=./storage/uploads
